    "bk_home_testimonials_Ak7LmQ": {
      "type": "bk-home-testimonials",
      "blocks": {
        "column_gtUXTw": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/UJ_Chanachoor_d3832fa6-a423-4691-bdc8-20be100ba928.jpg",
            "title": "Anirban Mitra",
            "text": "<p>&#9733;&#9733;&#9733;&#9733;&#9733;<br/>Excellent service! Authentic Chanachur from Kalighat store. The packaging kept it fresh and tasty.</p>",
            "link_label": "",
            "link": ""
          }
        },
        "column_cpfCQx": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/shop-premium-quality-aamshotto-now-at-bangla-konnection-404.png",
            "title": "Monali Sen",
            "text": "<p>&#9733;&#9733;&#9733;&#9733;&#9733;<br/>It feels just like buying from the para'r dokan: fresh, tasty, and packed with care for the probashi household.</p>",
            "link_label": "",
            "link": ""
          }
        },
        "column_grWRzG": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/Sona_Moong_d0d8bef0-1ab9-4ba0-829a-6887bbe2adee.jpg",
            "title": "Jayshree Dasgupta",
            "text": "<p>&#9733;&#9733;&#9733;&#9733;&#9733;<br/>The Sona Moong dal was top quality. Great taste, lovely aroma, and perfect for khichuri with Gobindobhog chal.</p>",
            "link_label": "",
            "link": ""
          }
        },
        "column_KYz9gE": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/Gobindobhog-550x550.jpg",
            "title": "Megha Guha",
            "text": "<p>&#9733;&#9733;&#9733;&#9733;&#9733;<br/>My go-to place for Gobindobhog. Delicious, earthy, and nostalgic every single time.</p>",
            "link_label": "",
            "link": ""
          }
        },
        "column_WQKdwC": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/darjeeling-leaf-supreme-tea_a016304b-31ce-4fa0-ae15-e6a0bb917ddf.jpg",
            "title": "Asim Biswas",
            "text": "<p>&#9733;&#9733;&#9733;&#9733;&#9733;<br/>This cha brings back the feel of typical Kolkata tea. A lovely way to reclaim bikeler cha from afar.</p>",
            "link_label": "",
            "link": ""
          }
        },
        "column_7JMwcE": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/Special_Masala_482cedb1-4b66-4aa7-bdca-655dac781022.jpg",
            "title": "Rahul Dasgupta",
            "text": "<p>&#9733;&#9733;&#9733;&#9733;&#9733;<br/>Love the full range of boris. The seasonal special masala bori is something I wait for every year.</p>",
            "link_label": "",
            "link": ""
          }
        },
        "column_DJbHFR": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/Himsagar_9f8015bd-750d-47a1-bf8c-db1822b1256a.jpg",
            "title": "Sayan Nandi",
            "text": "<p>&#9733;&#9733;&#9733;&#9733;&#9733;<br/>Himsagar aam away from Kolkata, packed fast and carefully. Every mango arrived fresh and in excellent shape.</p>",
            "link_label": "",
            "link": ""
          }
        },
        "column_JPj6jd": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/Hing_Chanachur_a9089940-92b0-47f9-850f-e30aab26cf55.jpg",
            "title": "Rahul Ghosh",
            "text": "<p>&#9733;&#9733;&#9733;&#9733;&#9733;<br/>The Tuk-Tak snack range is delicious. Perfect with kadak cha and exactly the kind of comfort I wanted.</p>",
            "link_label": "",
            "link": ""
          }
