{% comment %}theme-check-disable ImgLazyLoading{% endcomment %}
{{ 'component-collection-hero.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign bk_collection_description = collection.description | strip_html | strip
  if bk_collection_description == blank
    assign bk_collection_description = 'Browse familiar staples, sweets, and pantry favorites chosen to feel warm, useful, and close to home.'
  endif
-%}

{%- style -%}
  .bk-collection-hero-{{ section.id }} {
    position: relative;
    overflow: hidden;
    padding-top: clamp(1.2rem, 2vw, 2rem);
  }

  .bk-collection-hero-{{ section.id }} .collection-hero__inner {
    display: grid;
    gap: 2rem;
    align-items: center;
    padding: clamp(2rem, 4vw, 3.6rem);
    border: 0.1rem solid rgba(95, 39, 44, 0.1);
    border-radius: 3.2rem;
    background:
      radial-gradient(circle at top right, rgba(227, 158, 96, 0.16), transparent 38%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(242, 239, 221, 0.94));
    box-shadow: 0 2.2rem 5rem rgba(95, 39, 44, 0.08);
  }

  .bk-collection-hero-{{ section.id }} .collection-hero__text-wrapper {
    display: grid;
    gap: 1.2rem;
    max-width: 70rem;
  }

  .bk-collection-hero__eyebrow-{{ section.id }} {
    margin: 0;
    color: rgba(95, 39, 44, 0.68);
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .bk-collection-hero__meta-{{ section.id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .bk-collection-hero__meta-{{ section.id }} li {
    display: inline-flex;
    align-items: center;
    min-height: 3.4rem;
    padding: 0.65rem 1.1rem;
    border-radius: 999px;
    border: 0.1rem solid rgba(95, 39, 44, 0.12);
    background: rgba(255, 255, 255, 0.84);
    color: rgb(95, 39, 44);
    font-size: 1.08rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .bk-collection-hero-{{ section.id }} .collection-hero__title {
    margin: 0;
    color: rgb(95, 39, 44);
    font-size: clamp(3.4rem, 6vw, 5.8rem);
    line-height: 0.96;
    letter-spacing: -0.04em;
  }

  .bk-collection-hero-{{ section.id }} .collection-hero__description {
    margin: 0;
    color: rgba(95, 39, 44, 0.8);
    font-size: 1.65rem;
    line-height: 1.7;
    max-width: 58rem;
  }

  .bk-collection-hero-{{ section.id }} .collection-hero__description p:first-child {
    margin-top: 0;
  }

  .bk-collection-hero-{{ section.id }} .collection-hero__description p:last-child {
    margin-bottom: 0;
  }

  .bk-collection-hero-{{ section.id }} .collection-hero__image-container {
    overflow: hidden;
    border-radius: 2.8rem;
    border: 0.1rem solid rgba(95, 39, 44, 0.1);
    min-height: 100%;
  }

  .bk-collection-hero-{{ section.id }} .collection-hero__image-container img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media screen and (max-width: 749px) {
    .bk-collection-hero-{{ section.id }} .collection-hero__inner {
      padding: 1.8rem;
      border-radius: 2.4rem;
    }

    .bk-collection-hero-{{ section.id }} .collection-hero__description {
      font-size: 1.48rem;
      line-height: 1.65;
    }

    .collection-hero--with-image .collection-hero__inner {
      padding-bottom: calc({{ settings.media_shadow_vertical_offset | at_least: 0 }}px + 2rem);
    }
  }

  @media screen and (min-width: 990px) {
    .bk-collection-hero-{{ section.id }}.collection-hero--with-image .collection-hero__inner {
      grid-template-columns: minmax(0, 1.15fr) minmax(28rem, 0.85fr);
    }
  }
{%- endstyle -%}

<div class="collection-hero bk-collection-hero-{{ section.id }}{% if section.settings.show_collection_image and collection.image %} collection-hero--with-image{% endif %} color-{{ section.settings.color_scheme }} gradient">
  <div class="collection-hero__inner page-width {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
    <div class="collection-hero__text-wrapper">
      <p class="bk-collection-hero__eyebrow-{{ section.id }}">Bangla Konnection</p>
      <ul class="bk-collection-hero__meta-{{ section.id }}" role="list">
        <li>{{ collection.all_products_count }} products</li>
        <li>Shop by collection</li>
      </ul>
      <h1 class="collection-hero__title">
        <span class="visually-hidden">{{ 'sections.collection_template.title' | t }}: </span>
        {{- collection.title | escape -}}
      </h1>

      {%- if section.settings.show_collection_description -%}
        <div class="collection-hero__description rte">
          {%- if collection.description != blank -%}
            {{ collection.description }}
          {%- else -%}
            <p>{{ bk_collection_description }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    {%- if section.settings.show_collection_image and collection.image -%}
      <div class="collection-hero__image-container media gradient">
        <img
          srcset="
            {%- if collection.image.width >= 165 -%}{{ collection.image | image_url: width: 165 }} 165w,{%- endif -%}
            {%- if collection.image.width >= 360 -%}{{ collection.image | image_url: width: 360 }} 360w,{%- endif -%}
            {%- if collection.image.width >= 535 -%}{{ collection.image | image_url: width: 535 }} 535w,{%- endif -%}
            {%- if collection.image.width >= 750 -%}{{ collection.image | image_url: width: 750 }} 750w,{%- endif -%}
            {%- if collection.image.width >= 1070 -%}{{ collection.image | image_url: width: 1070 }} 1070w,{%- endif -%}
            {%- if collection.image.width >= 1500 -%}{{ collection.image | image_url: width: 1500 }} 1500w,{%- endif -%}
            {{ collection.image | image_url }} {{ collection.image.width }}w
          "
          src="{{ collection.image | image_url: width: 750 }}"
          sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 2 }}px, (min-width: 750px) calc(50vw - 130px), calc(50vw - 55px)"
          alt="{{ collection.image.alt | escape }}"
          width="{{ collection.image.width }}"
          height="{{ collection.image.height }}"
        >
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-collection-banner.name",
  "class": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.main-collection-banner.settings.paragraph.content"
    },
    {
      "type": "checkbox",
      "id": "show_collection_description",
      "default": true,
      "label": "t:sections.main-collection-banner.settings.show_collection_description.label"
    },
    {
      "type": "checkbox",
      "id": "show_collection_image",
      "default": false,
      "label": "t:sections.main-collection-banner.settings.show_collection_image.label",
      "info": "t:sections.main-collection-banner.settings.show_collection_image.info"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    }
  ]
}
{% endschema %}
