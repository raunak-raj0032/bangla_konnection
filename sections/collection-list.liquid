{{ 'section-collection-list.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #MainContent {
    background:
      radial-gradient(circle at top right, rgba(191, 128, 74, 0.16), transparent 30rem),
      radial-gradient(circle at bottom left, rgba(90, 27, 40, 0.08), transparent 28rem),
      linear-gradient(180deg, #fffdf9 0%, #fff6ed 100%);
  }

  #shopify-section-{{ section.id }} {
    position: relative;
    background: transparent;
  }

  #MainContent > .shopify-section.section-collection-list:first-of-type .bk-collection-divider {
    display: none;
  }

  .bk-collection-cluster-{{ section.id }} {
    --bk-collection-ink: 90, 27, 40;
    --bk-collection-accent: 191, 128, 74;
    --bk-collection-cream: 255, 248, 240;
    --bk-collection-divider-red-strong: 151, 15, 28;
    --bk-collection-divider-red-soft: 219, 54, 68;
    position: relative;
    margin-top: -0.1rem;
    padding-top: 0.1rem;
    overflow: clip;
    background: transparent;
    background-attachment: scroll;
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  .bk-collection-cluster-{{ section.id }} .collection-list-wrapper {
    position: relative;
    z-index: 1;
    display: grid;
    gap: clamp(1.8rem, 2.6vw, 2.8rem);
    padding-inline: clamp(0.8rem, 1.1vw, 1.2rem);
  }

  .bk-collection-cluster-{{ section.id }} .bk-collection-divider {
    position: relative;
    width: min(100%, 88rem);
    height: clamp(2.8rem, 3.6vw, 3.6rem);
    margin: 0 auto clamp(1.4rem, 2vw, 2.2rem);
  }

  .bk-collection-cluster-{{ section.id }} .bk-collection-divider::before {
    content: '';
    position: absolute;
    inset: 50% 0 auto;
    height: 0.16rem;
    z-index: 0;
    transform: translateY(-50%);
    background:
      linear-gradient(
        90deg,
        transparent 0%,
        rgba(var(--bk-collection-divider-red-soft), 0.08) 6%,
        rgba(var(--bk-collection-divider-red-soft), 0.3) 18%,
        rgba(var(--bk-collection-divider-red-strong), 0.72) 34%,
        rgba(var(--bk-collection-divider-red-soft), 0.92) 50%,
        rgba(var(--bk-collection-divider-red-strong), 0.72) 66%,
        rgba(var(--bk-collection-divider-red-soft), 0.3) 82%,
        rgba(var(--bk-collection-divider-red-soft), 0.08) 94%,
        transparent 100%
      );
    box-shadow: 0 0 1rem rgba(var(--bk-collection-divider-red-soft), 0.12);
  }

  .bk-collection-cluster-{{ section.id }} .bk-collection-divider::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: clamp(4.8rem, 5vw, 5.8rem);
    height: clamp(3.3rem, 3.6vw, 4rem);
    z-index: 1;
    transform: translate(-50%, -46%);
    background: linear-gradient(
      180deg,
      rgba(var(--bk-collection-divider-red-soft), 0.94) 0%,
      rgba(var(--bk-collection-divider-red-strong), 1) 100%
    );
    clip-path: polygon(50% 100%, 0 0, 100% 0);
    filter:
      drop-shadow(0 1rem 1.6rem rgba(95, 39, 44, 0.08))
      drop-shadow(0 0 0.95rem rgba(var(--bk-collection-divider-red-soft), 0.14));
  }

  .bk-collection-cluster-{{ section.id }} .bk-collection-divider > span {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
    z-index: 2;
    transform: translate(-50%, -38%);
  }

  .bk-collection-cluster-{{ section.id }} .bk-collection-divider > span::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 0.78rem;
    height: 0.78rem;
    z-index: 1;
    transform: translate(-50%, -48%);
    border-radius: 999px;
    background: rgba(var(--bk-collection-divider-red-strong), 1);
    box-shadow:
      0 0 0 0.18rem rgba(255, 244, 239, 0.92),
      0 0 0.55rem rgba(var(--bk-collection-divider-red-strong), 0.24);
  }

  .bk-collection-cluster-{{ section.id }} .bk-collection-divider > span::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: clamp(3.9rem, 4.1vw, 4.7rem);
    height: clamp(2.6rem, 2.9vw, 3.2rem);
    z-index: 0;
    transform: translate(-50%, -50%);
    background: rgba(255, 255, 255, 0.99);
    clip-path: polygon(50% 100%, 0 0, 100% 0);
  }

  .bk-collection-cluster-{{ section.id }} .title-wrapper-with-link {
    align-items: center;
    justify-content: space-between;
    gap: 1.6rem;
    margin-bottom: 0;
  }

  .bk-collection-cluster-{{ section.id }} .collection-list-title {
    margin: 0;
    color: rgb(var(--bk-collection-ink));
    line-height: 0.94;
    letter-spacing: -0.045em;
    text-transform: none;
    font-size: clamp(3rem, 2.2rem + 1.4vw, 4.8rem);
    max-width: 10ch;
    text-wrap: balance;
  }

  .bk-collection-cluster-{{ section.id }} .collection-list-title::after {
    display: none;
  }

  .bk-collection-cluster-{{ section.id }} #Slider-{{ section.id }} {
    gap: clamp(1.4rem, 1.8vw, 2rem);
    align-items: flex-start;
  }

  .bk-collection-cluster-{{ section.id }} .collection-list__item {
    display: flex;
    min-width: 0;
    align-self: flex-start;
  }

  .bk-collection-card-{{ section.id }} {
    width: 100%;
    height: auto;
  }

  .bk-collection-card-{{ section.id }} .card-wrapper,
  .bk-collection-card-{{ section.id }} .bk-collection-card--editorial {
    width: 100%;
    height: auto;
  }

  .bk-collection-card-{{ section.id }} .bk-collection-card--editorial {
    position: relative;
    overflow: hidden;
    border: 0.1rem solid rgba(var(--bk-collection-ink), 0.12);
    border-radius: 3rem;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(249, 242, 233, 0.94));
    box-shadow: none;
    transition: transform 0.28s ease;
  }

  .bk-collection-card-{{ section.id }} .bk-collection-card--editorial::before {
    content: '';
    position: absolute;
    inset: auto -16% -34% auto;
    width: 20rem;
    height: 20rem;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(var(--bk-collection-accent), 0.18) 0%, transparent 72%);
    pointer-events: none;
  }

  .bk-collection-card-{{ section.id }} .bk-collection-card--editorial:hover {
    transform: translateY(-0.45rem);
    box-shadow: none;
  }

  .bk-collection-card-{{ section.id }} .bk-collection-card__link {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    min-height: 0;
    color: inherit;
    text-decoration: none;
  }

  .bk-collection-card-{{ section.id }} .bk-collection-card__media-shell {
    position: relative;
    padding: 1.1rem 1.1rem 0;
  }

  .bk-collection-card-{{ section.id }} .bk-collection-card__media {
    position: relative;
    width: 100%;
    padding-top: min(var(--bk-collection-ratio-percent), 116%);
    overflow: hidden;
    border-radius: 2.3rem;
    background: linear-gradient(135deg, rgba(var(--bk-collection-ink), 0.12), rgba(var(--bk-collection-accent), 0.12));
  }

  .bk-collection-card-{{ section.id }} .bk-collection-card__media::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 22%, rgba(64, 23, 30, 0.1) 100%);
    pointer-events: none;
  }

  .bk-collection-card-{{ section.id }} .bk-collection-card__media img,
  .bk-collection-card-{{ section.id }} .bk-collection-card__media .placeholder-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .bk-collection-card-{{ section.id }} .bk-collection-card__media img {
    object-fit: cover;
    transition: transform 0.4s ease, filter 0.35s ease;
  }

  .bk-collection-card-{{ section.id }} .bk-collection-card--editorial:hover .bk-collection-card__media img {
    transform: scale(1.045);
    filter: saturate(1.06);
  }

  .bk-collection-card-{{ section.id }} .bk-collection-card__placeholder {
    padding: 14%;
    background: linear-gradient(180deg, rgba(255, 252, 248, 0.9), rgba(244, 234, 219, 0.96));
    fill: rgba(var(--bk-collection-ink), 0.2);
  }

  .bk-collection-card-{{ section.id }} .bk-collection-card__kicker,
  .bk-collection-card-{{ section.id }} .bk-collection-card__cta {
    font-size: 1.02rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .bk-collection-card-{{ section.id }} .bk-collection-card__body {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    margin: -3.8rem 1.2rem 1.2rem;
    padding: 1.5rem;
    min-height: 13.2rem;
    border: 0.1rem solid rgba(var(--bk-collection-ink), 0.08);
    border-radius: 2.2rem;
    background: #ffffff;
    box-shadow: none;
  }

  .bk-collection-card-{{ section.id }} .bk-collection-card__topline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .bk-collection-card-{{ section.id }} .bk-collection-card__kicker,
  .bk-collection-card-{{ section.id }} .bk-collection-card__cta {
    color: rgba(var(--bk-collection-ink), 0.6);
  }

  .bk-collection-card-{{ section.id }} .bk-collection-card__kicker {
    margin: 0;
  }

  .bk-collection-card-{{ section.id }} .bk-collection-card__arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.2rem;
    height: 3.2rem;
    border-radius: 999px;
    background: rgb(var(--bk-collection-ink));
    color: #fff7ef;
    flex-shrink: 0;
    transition: transform 0.28s ease, background-color 0.28s ease;
  }

  .bk-collection-card-{{ section.id }} .bk-collection-card__arrow svg {
    width: 1.4rem;
    height: 1.4rem;
  }

  .bk-collection-card-{{ section.id }} .bk-collection-card--editorial:hover .bk-collection-card__arrow {
    transform: translateX(0.2rem);
    background: rgba(var(--bk-collection-accent), 0.9);
  }

  .bk-collection-card-{{ section.id }} .bk-collection-card__title {
    margin: 0;
    color: rgb(var(--bk-collection-ink));
    font-size: clamp(2.2rem, 1.9rem + 0.7vw, 3rem);
    line-height: 1;
    letter-spacing: -0.04em;
    overflow: hidden;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .bk-collection-card-{{ section.id }} .bk-collection-card__excerpt {
    display: none;
  }

  .bk-collection-card-{{ section.id }} .bk-collection-card__cta {
    display: inline-flex;
    align-items: center;
    color: rgb(var(--bk-collection-ink));
    margin-top: auto;
  }

  .bk-collection-card-{{ section.id }} .bk-collection-card--no-media .bk-collection-card__media {
    padding-top: 78%;
  }

  .bk-collection-card-{{ section.id }} .bk-collection-card--extend-height .bk-collection-card__link {
    min-height: 0;
  }

  .bk-collection-cluster-{{ section.id }} .slider-buttons {
    margin-top: 0.4rem;
    justify-content: flex-end;
    gap: 0.8rem;
  }

  .bk-collection-cluster-{{ section.id }} .slider-button,
  .bk-collection-cluster-{{ section.id }} .slider-counter {
    border: 0.1rem solid rgba(var(--bk-collection-ink), 0.08);
    border-radius: 999px;
    background: rgba(255, 250, 245, 0.94);
    box-shadow: 0 1rem 2rem rgba(95, 39, 44, 0.06);
  }

  .bk-collection-cluster-{{ section.id }} .slider-button {
    width: 4rem;
    height: 4rem;
  }

  .bk-collection-cluster-{{ section.id }} .slider-counter {
    min-width: auto;
    padding: 0.8rem 1.2rem;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .bk-collection-cluster-{{ section.id }} .collection-list-wrapper {
      gap: 1.4rem;
      padding-inline: 0.25rem;
    }

    .bk-collection-cluster-{{ section.id }} .bk-collection-divider {
      width: min(100%, 34rem);
      height: 3rem;
      margin-bottom: 1.1rem;
    }

    .bk-collection-cluster-{{ section.id }} .bk-collection-divider::after {
      width: 4.2rem;
      height: 3rem;
    }

    .bk-collection-cluster-{{ section.id }} .bk-collection-divider > span {
      width: 0;
      height: 0;
    }

    .bk-collection-cluster-{{ section.id }} .bk-collection-divider > span::before {
      width: 0.7rem;
      height: 0.7rem;
    }

    .bk-collection-cluster-{{ section.id }} .bk-collection-divider > span::after {
      width: 3.4rem;
      height: 2.4rem;
    }

    .bk-collection-cluster-{{ section.id }} .title-wrapper-with-link {
      align-items: flex-start;
      gap: 1rem;
    }

    .bk-collection-cluster-{{ section.id }} #Slider-{{ section.id }} {
      gap: 1.2rem;
    }

    .bk-collection-cluster-{{ section.id }} .collection-list-title {
      max-width: none;
      font-size: clamp(2.4rem, 6vw, 3.4rem);
    }

    .bk-collection-card-{{ section.id }} .bk-collection-card--editorial {
      border-radius: 2.2rem;
    }

    .bk-collection-card-{{ section.id }} .bk-collection-card__media-shell {
      padding: 0.9rem 0.9rem 0;
    }

    .bk-collection-card-{{ section.id }} .bk-collection-card__media {
      border-radius: 1.7rem;
    }

    .bk-collection-card-{{ section.id }} .bk-collection-card__kicker,
    .bk-collection-card-{{ section.id }} .bk-collection-card__cta {
      font-size: 0.9rem;
      letter-spacing: 0.15em;
    }

    .bk-collection-card-{{ section.id }} .bk-collection-card__body {
      gap: 0.7rem;
      margin: -2.6rem 0.9rem 0.9rem;
      padding: 1.15rem;
      min-height: 11.2rem;
      border-radius: 1.6rem;
    }

    .bk-collection-card-{{ section.id }} .bk-collection-card__arrow {
      width: 2.7rem;
      height: 2.7rem;
    }

    .bk-collection-card-{{ section.id }} .bk-collection-card__arrow svg {
      width: 1.2rem;
      height: 1.2rem;
    }

    .bk-collection-card-{{ section.id }} .bk-collection-card__title {
      font-size: clamp(1.95rem, 4.8vw, 2.55rem);
    }

    .bk-collection-cluster-{{ section.id }} .slider-buttons {
      justify-content: center;
      margin-top: 0.2rem;
    }
  }
{%- endstyle -%}

{%- liquid
  assign columns_mobile_int = section.settings.columns_mobile | plus: 0
  assign show_mobile_slider = false
  assign bk_collection_card_wrapper = 'bk-collection-card-' | append: section.id
  if section.settings.swipe_on_mobile and section.blocks.size > columns_mobile_int
    assign show_mobile_slider = true
  endif
-%}

<div class="color-{{ section.settings.color_scheme }} gradient bk-collection-cluster-{{ section.id }}">
  <div class="collection-list-wrapper page-width isolate{% if show_mobile_slider %} page-width-desktop{% endif %}{% if section.settings.title == blank %} no-heading{% endif %}{% if section.settings.show_view_all == false or section.blocks.size > collections.size %} no-mobile-link{% endif %} section-{{ section.id }}-padding">
    <div class="bk-collection-divider" aria-hidden="true"><span></span></div>
    {%- unless section.settings.title == blank -%}
      <div class="title-wrapper-with-link{% if show_mobile_slider %} title-wrapper--self-padded-tablet-down{% else %} title-wrapper--self-padded-mobile{% endif %} title-wrapper--no-top-margin">
        <h2
          id="SectionHeading-{{ section.id }}"
          class="collection-list-title inline-richtext {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
        >
          {{ section.settings.title }}
        </h2>

      </div>
    {%- endunless -%}

    <slider-component class="slider-mobile-gutter{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      <ul
        class="collection-list contains-card contains-card--collection{% if settings.card_style == 'standard' %} contains-card--standard{% endif %} grid grid--{{ section.settings.columns_desktop }}-col-desktop grid--{{ section.settings.columns_mobile }}-col-tablet-down{% if section.settings.swipe_on_mobile %} slider slider--tablet grid--peek{% endif %} collection-list--{{ section.blocks.size }}-items"
        id="Slider-{{ section.id }}"
        role="list"
      >
        {%- liquid
          assign columns = section.blocks.size
          if columns > 3
            assign columns = 3
          endif
        -%}
        {%- for block in section.blocks -%}
          <li
            id="Slide-{{ section.id }}-{{ forloop.index }}"
            class="collection-list__item grid__item{% if show_mobile_slider %} slider__slide{% endif %}{% if block.settings.collection.featured_image == nil %} collection-list__item--no-media{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {{ block.shopify_attributes }}
            {% if settings.animations_reveal_on_scroll %}
              data-cascade
              style="--animation-order: {{ forloop.index }};"
            {% endif %}
          >
            {%- assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 -%}
            {%- assign placeholder_image = 'collection-apparel-' | append: placeholder_image_index -%}
            {% render 'card-collection',
              card_collection: block.settings.collection,
              media_aspect_ratio: section.settings.image_ratio,
              columns: columns,
              placeholder_image: placeholder_image,
              wrapper_class: bk_collection_card_wrapper,
              show_collection_count: true,
              layout_style: 'editorial'
            %}
          </li>
        {%- endfor -%}
      </ul>
      {%- if show_mobile_slider -%}
        <div class="slider-buttons">
          <button
            type="button"
            class="slider-button slider-button--prev"
            name="previous"
            aria-label="{{ 'general.slider.previous_slide' | t }}"
          >
            {% render 'icon-caret' %}
          </button>
          <div class="slider-counter caption">
            <span class="slider-counter--current">1</span>
            <span aria-hidden="true"> / </span>
            <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
            <span class="slider-counter--total">{{ section.blocks.size }}</span>
          </div>
          <button
            type="button"
            class="slider-button slider-button--next"
            name="next"
            aria-label="{{ 'general.slider.next_slide' | t }}"
          >
            {% render 'icon-caret' %}
          </button>
        </div>
      {%- endif -%}
    </slider-component>

  </div>
</div>

{% schema %}
{
  "name": "t:sections.collection-list.name",
  "tag": "section",
  "class": "section section-collection-list",
  "max_blocks": 15,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "t:sections.collection-list.settings.title.default",
      "label": "t:sections.collection-list.settings.title.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        },
        {
          "value": "hxl",
          "label": "t:sections.all.heading_size.options__4.label"
        },
        {
          "value": "hxxl",
          "label": "t:sections.all.heading_size.options__5.label"
        }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:sections.collection-list.settings.image_ratio.options__1.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.collection-list.settings.image_ratio.options__2.label"
        },
        {
          "value": "square",
          "label": "t:sections.collection-list.settings.image_ratio.options__3.label"
        }
      ],
      "default": "square",
      "label": "t:sections.collection-list.settings.image_ratio.label",
      "info": "t:sections.collection-list.settings.image_ratio.info"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3,
      "label": "t:sections.collection-list.settings.columns_desktop.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "info": "t:sections.all.colors.has_cards_info",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "default": false,
      "label": "t:sections.collection-list.settings.show_view_all.label"
    },
    {
      "type": "header",
      "content": "t:sections.collection-list.settings.header_mobile.content"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "options": [
        {
          "value": "1",
          "label": "t:sections.collection-list.settings.columns_mobile.options__1.label"
        },
        {
          "value": "2",
          "label": "t:sections.collection-list.settings.columns_mobile.options__2.label"
        }
      ],
      "default": "1",
      "label": "t:sections.collection-list.settings.columns_mobile.label"
    },
    {
      "type": "checkbox",
      "id": "swipe_on_mobile",
      "default": false,
      "label": "t:sections.collection-list.settings.swipe_on_mobile.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "blocks": [
