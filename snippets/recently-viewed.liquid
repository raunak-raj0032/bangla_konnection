<style>
  .bk-recently-viewed {
    margin-top: clamp(4rem, 7vw, 7rem);
    padding-top: clamp(3rem, 5vw, 4.8rem);
    border-top: 0.1rem solid rgba(90, 27, 40, 0.12);
  }

  .bk-recently-viewed[hidden] {
    display: none !important;
  }

  .bk-recently-viewed__title {
    margin: 0 0 2rem;
    color: #5a1b28;
    font-size: clamp(3rem, 4vw, 4.2rem);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .bk-recently-viewed__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(22rem, 100%), 26rem));
    gap: 2rem;
    align-items: start;
    justify-content: start;
  }

  .bk-recently-viewed__item {
    min-width: 0;
  }

  .bk-recently-viewed__card {
    height: 100%;
    padding: 1rem;
    border: 0.1rem solid rgba(90, 27, 40, 0.12);
    border-radius: 2.4rem;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(255, 246, 237, 0.92));
    box-shadow: 0 1.8rem 3.6rem rgba(95, 39, 44, 0.08);
  }

  .bk-recently-viewed__media {
    display: block;
    aspect-ratio: 4 / 5;
    border-radius: 1.8rem;
    overflow: hidden;
    background: linear-gradient(180deg, rgba(244, 231, 214, 0.95), rgba(230, 206, 177, 0.9));
  }

  .bk-recently-viewed__media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .bk-recently-viewed__card:hover .bk-recently-viewed__media img {
    transform: scale(1.03);
  }

  .bk-recently-viewed__body {
    display: grid;
    gap: 0.8rem;
    padding: 1.4rem 0.4rem 0.2rem;
  }

  .bk-recently-viewed__eyebrow {
    margin: 0;
    color: rgba(90, 27, 40, 0.58);
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .bk-recently-viewed__product-title {
    margin: 0;
    font-size: 2rem;
    line-height: 1.2;
  }

  .bk-recently-viewed__product-title a {
    color: #3f1520;
    text-decoration: none;
  }

  .bk-recently-viewed__price {
    margin: 0;
    color: #5a1b28;
    font-size: 1.9rem;
    font-weight: 700;
    line-height: 1.1;
  }

  @media only screen and (max-width: 989px) {
    .bk-recently-viewed__grid {
      grid-template-columns: repeat(auto-fit, minmax(min(19rem, 100%), 1fr));
    }
  }

  @media only screen and (max-width: 749px) {
    .bk-recently-viewed__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1.4rem;
    }

    .bk-recently-viewed__title {
      margin-bottom: 1.6rem;
      font-size: 2.6rem;
    }

    .bk-recently-viewed__card {
      padding: 0.8rem;
      border-radius: 1.8rem;
    }

    .bk-recently-viewed__media {
      border-radius: 1.4rem;
    }

    .bk-recently-viewed__body {
      gap: 0.7rem;
      padding: 1.1rem 0.2rem 0.1rem;
    }

    .bk-recently-viewed__product-title {
      font-size: 1.6rem;
    }

    .bk-recently-viewed__price {
      font-size: 1.6rem;
    }
  }
</style>

<script>
  (function () {
    const storageKey = 'recently_viewed';
    const maxProducts = 4;

    const currentProduct = {
      productTitle: {{ product.title | json }},
      productImg: {{ product.featured_image | image_url: width: 900 | json }},
      productPrice: {{ product.price | money | json }},
      productUrl: {{ product.url | json }}
    };

    let storedProducts = [];

    try {
      storedProducts = JSON.parse(localStorage.getItem(storageKey)) || [];
    } catch (error) {
      storedProducts = [];
    }

    if (!Array.isArray(storedProducts)) {
      storedProducts = [];
    }

    storedProducts = storedProducts.filter(function (item) {
      return item && item.productUrl !== currentProduct.productUrl;
    });

    storedProducts.push(currentProduct);

    if (storedProducts.length > maxProducts) {
      storedProducts = storedProducts.slice(storedProducts.length - maxProducts);
    }

    localStorage.setItem(storageKey, JSON.stringify(storedProducts));
  })();
</script>

<div class="bk-recently-viewed" data-recently-viewed-root hidden>
  <h2 class="bk-recently-viewed__title title inline-richtext h2 scroll-trigger animate--slide-in">
    Recently Viewed
  </h2>
  <div class="bk-recently-viewed__grid js-recentPdpBlock"></div>
</div>

<script>
  (function () {
    const storageKey = 'recently_viewed';
    const currentProductUrl = {{ product.url | json }};
    const root = document.querySelector('[data-recently-viewed-root]');

    function escapeHtml(value) {
      return String(value)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    if (!root) {
      return;
    }

    const contentBlock = root.querySelector('.js-recentPdpBlock');

    if (!contentBlock) {
      return;
    }

    let storedProducts = [];

    try {
      storedProducts = JSON.parse(localStorage.getItem(storageKey)) || [];
    } catch (error) {
      storedProducts = [];
    }

    if (!Array.isArray(storedProducts)) {
      storedProducts = [];
    }

    const recentProducts = storedProducts
      .filter(function (item) {
        return item && item.productUrl && item.productUrl !== currentProductUrl;
      })
      .reverse();

    if (!recentProducts.length) {
      root.hidden = true;
      return;
    }

    const recentViewHtml = recentProducts
      .map(function (item) {
        const safeTitle = escapeHtml(item.productTitle || '');
        const safeUrl = escapeHtml(item.productUrl || '');
        const safePrice = escapeHtml(item.productPrice || '');
        const imageMarkup = item.productImg
          ? "<img src=\"" + item.productImg + "\" alt=\"" + safeTitle + "\" loading=\"lazy\">"
          : '';

        return (
          "<article class=\"bk-recently-viewed__item\">" +
            "<div class=\"bk-recently-viewed__card\">" +
              "<a class=\"bk-recently-viewed__media\" href=\"" + safeUrl + "\">" +
                imageMarkup +
              "</a>" +
              "<div class=\"bk-recently-viewed__body\">" +
                "<p class=\"bk-recently-viewed__eyebrow\">Recently viewed</p>" +
                "<h3 class=\"bk-recently-viewed__product-title\">" +
                  "<a class=\"c-product__url\" href=\"" + safeUrl + "\">" + safeTitle + "</a>" +
                "</h3>" +
                "<p class=\"bk-recently-viewed__price\">" + safePrice + "</p>" +
              "</div>" +
            "</div>" +
          "</article>"
        );
      })
      .join('');

    contentBlock.innerHTML = recentViewHtml;
    root.hidden = false;
  })();
</script>
